  "semanticHighlighting": true,
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#55b64f"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.language"
      ],
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": [
        "entity",
        "entity.name"
      ],
      "settings": {
        "foreground": "#4091DA"
      }
    },
    {
      "scope": "variable.parameter.function",
      "settings": {
        "foreground": "#E6E6F0"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#55b64f"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#fe0000"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#fe0000"
      }
    },
    {
      "scope": [
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": {
        "foreground": "#E6E6F0"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "string punctuation.section.embedded source"
      ],
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "support",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "meta.property-name",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#f9be1c"
      }
    },
    {
      "scope": "variable.other",
      "settings": {
        "foreground": "#E6E6F0"
      }
    },
    {
      "scope": "invalid.broken",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fe0000"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fe0000"
      }
    },
    {
      "scope": "invalid.illegal",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fe0000"
      }
    },
    {
      "scope": "invalid.unimplemented",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fe0000"
      }
    },
    {
      "scope": "carriage-return",
      "settings": {
        "fontStyle": "italic underline",
        "background": "#fe0000",
        "foreground": "#16161d",
        "content": "^M"
      }
    },
    {
      "scope": "message.error",
      "settings": {
        "foreground": "#fe0000"
      }
    },
    {
      "scope": "string variable",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": [
        "source.regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "string.regexp constant.character.escape",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#55b64f"
      }
    },
    {
      "scope": "support.constant",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "support.variable",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "meta.module-reference",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#EA6135"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#55b64f"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#E6E6F0"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#E6E6F0"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "background": "#fe0000",
        "foreground": "#fe0000"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "background": "#55b64f",
        "foreground": "#55b64f"
      }
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "background": "#EA6135",
        "foreground": "#EA6135"
      }
    },
    {
      "scope": [
        "markup.ignored",
        "markup.untracked"
      ],
      "settings": {
        "foreground": "#20202A",
        "background": "#a2e7fa"
      }
    },
    {
      "scope": "meta.diff.range",
      "settings": {
        "foreground": "#4091DA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "meta.separator",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": "meta.output",
      "settings": {
        "foreground": "#a2e7fa"
      }
    },
    {
      "scope": [
        "brackethighlighter.tag",
        "brackethighlighter.curly",
        "brackethighlighter.round",
        "brackethighlighter.square",
        "brackethighlighter.angle",
        "brackethighlighter.quote"
      ],
      "settings": {
        "foreground": "#C8C8D4"
      }
    },
    {
      "scope": "brackethighlighter.unmatched",
      "settings": {
        "foreground": "#fe0000"
      }
    },
    {
      "scope": [
        "constant.other.reference.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#a2e7fa",
        "fontStyle": "underline"
      }
    }
  ]
}